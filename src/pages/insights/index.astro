---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('insights'))
	.filter(post => !post.data.draft)
	.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="Insights">
	<header class="py-20 border-b border-white/5 mb-12">
		<h1 class="font-outfit text-5xl font-black mb-4">Insights</h1>
		<p class="text-white/40 text-lg">Musings on product, AI, and the future of building.</p>
	</header>

	<div class="grid grid-cols-1 gap-12">
		{posts.map(post => (
			<a href={`/insights/${post.slug}`} class="group flex flex-col md:flex-row gap-8 items-start">
				{post.data.summaryImage && (
					<div class="w-full md:w-64 aspect-video rounded-2xl overflow-hidden border border-white/5">
						<img src={`/images/${post.data.summaryImage}`} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
					</div>
				)}
				<div class="flex-1">
					<time class="text-xs font-bold tracking-widest text-accent uppercase mb-2 block">{new Date(post.data.date).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })}</time>
					<h2 class="font-outfit text-3xl font-bold mb-4 group-hover:text-accent transition-colors">{post.data.title}</h2>
					<p class="text-white/60 line-clamp-2 font-light">Explore this deep dive into {post.data.title}.</p>
				</div>
			</a>
		))}
	</div>
</Layout>
