---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
	<section class="min-h-[70vh] flex flex-col items-center justify-center text-center py-20">
		<h1 class="font-outfit text-6xl md:text-8xl font-black tracking-tight mb-8 leading-[0.9]">
			Product Manager <br/> 
			<span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-amber-200">
				to Product Builder
			</span>
		</h1>
		<p class="max-w-2xl text-lg md:text-xl text-white/40 font-light leading-relaxed mb-12">
			Building the future of digital products. Specializing in strategic PM expertise, advanced AI agents, and custom builds.
		</p>
	</section>

	<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
		<!-- PM Redefined -->
		<a href="/insights/pm-redefined" class="group relative p-8 rounded-3xl border border-white/5 bg-white/[0.02] backdrop-blur-xl overflow-hidden hover:border-accent/40 transition-all duration-500">
			<div class="absolute inset-0 bg-gradient-to-b from-accent/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
			<div class="relative z-10">
				<div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
					<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
					</svg>
				</div>
				<h3 class="font-outfit text-2xl font-bold mb-3">PM - Redefined</h3>
				<p class="text-sm text-white/50 leading-relaxed mb-6">Strategic product leadership. Deep market insights. Roadmaps that drive growth and deliver impact.</p>
				<span class="text-xs font-black tracking-widest uppercase text-accent">Learn More ↗</span>
			</div>
		</a>

		<!-- AI Agents -->
		<a href="/insights/ai-agents" class="group relative p-8 rounded-3xl border border-white/5 bg-white/[0.02] backdrop-blur-xl overflow-hidden hover:border-accent/40 transition-all duration-500">
			<div class="absolute inset-0 bg-gradient-to-b from-accent/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
			<div class="relative z-10">
				<div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
					<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
					</svg>
				</div>
				<h3 class="font-outfit text-2xl font-bold mb-3">AI Agents</h3>
				<p class="text-sm text-white/50 leading-relaxed mb-6">Pioneering intelligent solutions. Developing autonomous agents that optimize workflows and scale operations.</p>
				<span class="text-xs font-black tracking-widest uppercase text-accent">Learn More ↗</span>
			</div>
		</a>

		<!-- Builds -->
		<a href="/builds" class="group relative p-8 rounded-3xl border border-white/5 bg-white/[0.02] backdrop-blur-xl overflow-hidden hover:border-accent/40 transition-all duration-500">
			<div class="absolute inset-0 bg-gradient-to-b from-accent/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
			<div class="relative z-10">
				<div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
					<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
					</svg>
				</div>
				<h3 class="font-outfit text-2xl font-bold mb-3">Builds</h3>
				<p class="text-sm text-white/50 leading-relaxed mb-6">End-to-end product development. From ideation to launch. Crafting seamless and scalable digital products.</p>
				<span class="text-xs font-black tracking-widest uppercase text-accent">Learn More ↗</span>
			</div>
		</a>
	</div>
</Layout>
