---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About">
	<section class="py-20 max-w-4xl mx-auto">
		<header class="mb-16">
			<h1 class="font-outfit text-6xl font-black mb-6">About the Builder</h1>
			<p class="text-white/40 text-xl font-light leading-relaxed">
				Generative AI Solutions Leader shaping the future of enterprise tech.
			</p>
		</header>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-12 items-start">
			<div class="md:col-span-2 space-y-8 text-white/70 leading-relaxed font-light">
				<p>
					I'm <strong>Kanchana Patlolla</strong>. My work involves defining portfolio strategy for Databases and AI agents, working directly with customers to understand their needs, and driving the creation of core resources—from reference architectures to near-production functional demos.
				</p>
				<p>
					With an engineer's foundation in databases, I bring deep technical expertise to the world of AI. I was a key leader behind the release of <strong>Open Data QnA</strong> and the <strong>Agent Development Kit</strong> for Vertex AI.
				</p>
				
				<div class="bg-white/[0.02] border border-white/5 p-8 rounded-3xl">
					<h2 class="font-outfit text-2xl font-bold mb-6 text-white text-accent">Strategic Focus</h2>
					<ul class="grid grid-cols-1 gap-4 text-sm">
						<li class="flex items-start gap-3">
							<span class="text-accent">✔</span>
							<span>Innovation (Design Thinking & Use Case Prioritization)</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="text-accent">✔</span>
							<span>AI/ML Solutions (Document AI, Vertex AI, Agent Garden)</span>
						</li>
						<li class="flex items-start gap-3">
							<span class="text-accent">✔</span>
							<span>Enterprise Cloud Architecture & Serverless Data</span>
						</li>
					</ul>
				</div>
			</div>

			<aside class="space-y-8">
				<div class="w-full aspect-square rounded-3xl overflow-hidden border border-white/5">
					<img src="/images/headshot.jpeg" alt="Kanchana Patlolla" class="w-full h-full object-cover grayscale brightness-110 contrast-125" />
				</div>
				<div class="space-y-4">
					<h3 class="font-outfit text-xs font-black tracking-widest uppercase text-white/30">Connect</h3>
					<div class="flex flex-col gap-3 text-sm">
						<a href="mailto:kanch@cloudrace.info" class="text-accent hover:underline">kanch@cloudrace.info</a>
						<a href="https://linkedin.com/in/kanchanapatlolla" class="text-white/60 hover:text-white">LinkedIn</a>
						<a href="https://github.com/kanchpat" class="text-white/60 hover:text-white">GitHub</a>
					</div>
				</div>
			</aside>
		</div>

		<section class="mt-24 py-20 border-t border-white/5">
			<h2 class="font-outfit text-4xl font-black mb-12">Intention</h2>
			<blockquote class="text-2xl font-light text-white/40 border-l-4 border-accent pl-8 py-2 italic leading-relaxed">
				"Learning is a marathon, not a sprint. This site is my personal laboratory for navigating the ever-changing cloud race."
			</blockquote>
		</section>
	</section>
</Layout>
